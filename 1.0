                <div class="meal-name">Changua criolla con pan artesanal</div>
                <div class="meal-desc">Leche de coco, huevo, cilantro, pan de maíz GF</div>
                <div class="meal-tags"><span class="mtag gf">GF</span></div>
              </div>
            </div>
            <div class="meal-row">
              <div class="meal-time-col"><div class="meal-time">Almuerzo</div></div>
              <div class="meal-icon-wrap" style="background:#FFF5EE;">🥩</div>
              <div class="meal-details">
                <div class="meal-name">Asado familiar estilo Boyacá</div>
                <div class="meal-desc">Cortes seleccionados, chorizos artesanales, ensaladas</div>
                <div class="meal-tags"><span class="mtag gf">GF</span></div>
              </div>
            </div>
            <div class="meal-row">
              <div class="meal-time-col"><div class="meal-time">Postre</div></div>
              <div class="meal-icon-wrap" style="background:#FDF0F8;">🍮</div>
              <div class="meal-details">
                <div class="meal-name">Mesa de postres artesanales</div>
                <div class="meal-desc">Dulce de leche GF, bizcocho de achira, obleas</div>
                <div class="meal-tags"><span class="mtag sf">Sin azúcar</span><span class="mtag gf">GF</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="share-footer">
        <div class="share-count-row">
          <span class="sel-count" id="sel-count">0 platos seleccionados</span>
          <span style="font-size:10px;color:rgba(139,96,16,0.5);">toca la galería para elegir</span>
        </div>
        <button class="share-btn-main" id="share-btn">
          <i class="ti ti-send"></i>Comparte tu menú con el chef
        </button>
      </div>

      <div class="toast" id="toast">¡Menú enviado! El chef te contactará pronto.</div>

    </div>

    <div class="bottom-nav">
      <div class="nav-i"><i class="ti ti-home"></i><span class="nav-lbl">Inicio</span></div>
      <div class="nav-i"><i class="ti ti-calendar"></i><span class="nav-lbl">Reservas</span></div>
      <div class="nav-i active"><i class="ti ti-chef-hat"></i><span class="nav-lbl">Chef</span></div>
      <div class="nav-i"><i class="ti ti-user"></i><span class="nav-lbl">Perfil</span></div>
    </div>
  </div>

</div><!-- /phone -->
</div><!-- /phone-wrap -->

<script>
const chefs = [
  { initials:'MV', bg:'linear-gradient(135deg,#8B4513,#5C2D0A)', name:'Mariana Valdivia', exp:'14 años de experiencia', rating:'4.9 · 87 reseñas', specs:['Cocina andina','Postres sin azúcar','Gluten Free','Vegana','Tradición Boyacá'] },
  { initials:'CR', bg:'linear-gradient(135deg,#1A5276,#0B3D6B)', name:'Carlos Restrepo', exp:'9 años de experiencia', rating:'4.8 · 64 reseñas', specs:['Tradición Medellín','Cocina Francesa','Vegana','Sin lactosa'] },
  { initials:'SP', bg:'linear-gradient(135deg,#1E8449,#0E5C2A)', name:'Sofía Pedraza', exp:'18 años de experiencia', rating:'5.0 · 132 reseñas', specs:['Cocina del Pacífico','Mariscos','Kosher','Experiencias'] },
  { initials:'JM', bg:'linear-gradient(135deg,#7D3C98,#4A1A6B)', name:'Jorge Montoya', exp:'11 años de experiencia', rating:'4.7 · 53 reseñas', specs:['Repostería','Postres GF','Tolima','Sin azúcar'] },
];

// Splash
setTimeout(() => document.getElementById('splash-tag').classList.add('show'), 400);
setTimeout(() => document.getElementById('lid-top').classList.add('open'), 900);
setTimeout(() => {
  document.getElementById('splash').classList.add('hide');
  const hs = document.getElementById('home-screen');
  hs.classList.add('show');
}, 2000);

// Menu / dropdown
const menuBtn = document.getElementById('menu-btn');
const dropdown = document.getElementById('dropdown');
menuBtn.addEventListener('click', e => { e.stopPropagation(); dropdown.classList.toggle('open'); });
document.addEventListener('click', () => dropdown.classList.remove('open'));

// Chips
document.querySelectorAll('.chip').forEach(c => c.addEventListener('click', () => c.classList.toggle('active')));

// Chef cards → detail
const detail = document.getElementById('chef-detail');
document.querySelectorAll('.chef-card').forEach(card => {
  card.addEventListener('click', () => {
    const ch = chefs[+card.dataset.chef];
    document.getElementById('detail-avatar').textContent = ch.initials;
    document.getElementById('detail-avatar').style.background = ch.bg;
    document.getElementById('detail-name').textContent = ch.name;
    document.getElementById('detail-exp').innerHTML = `<i class="ti ti-award" style="font-size:10px;"></i> ${ch.exp}`;
    document.getElementById('detail-rating').textContent = ch.rating;
    const specsEl = document.getElementById('detail-specs');
    specsEl.innerHTML = ch.specs.map(s => `<span class="spec-tag">${s}</span>`).join('');
    detail.classList.add('show');
    // reset panels
    document.getElementById('gallery-panel').classList.remove('open');
    document.getElementById('add-panel').classList.remove('open');
    document.getElementById('btn-galeria').innerHTML = '<i class="ti ti-sparkles"></i>Crea tu menú';
    document.getElementById('btn-adicionales').innerHTML = '<i class="ti ti-plus"></i>Adicionales';
    document.getElementById('sel-count').textContent = '0 platos seleccionados';
    document.querySelectorAll('.g-item').forEach(g => g.classList.remove('sel'));
    selCount = 0;
  });
});

// Back
document.getElementById('back-btn').addEventListener('click', () => detail.classList.remove('show'));

// Tabs
document.querySelectorAll('.tab').forEach(t => {
  t.addEventListener('click', () => {
    document.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
    t.classList.add('active');
    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
    document.getElementById('tab-' + t.dataset.tab).classList.add('active');
  });
});

// Gallery toggle
const galleryPanel = document.getElementById('gallery-panel');
const addPanel = document.getElementById('add-panel');
document.getElementById('btn-galeria').addEventListener('click', () => {
  const open = galleryPanel.classList.contains('open');
  galleryPanel.classList.toggle('open', !open);
  addPanel.classList.remove('open');
  document.getElementById('btn-adicionales').innerHTML = '<i class="ti ti-plus"></i>Adicionales';
  document.getElementById('btn-galeria').innerHTML = open
    ? '<i class="ti ti-sparkles"></i>Crea tu menú'
    : '<i class="ti ti-x"></i>Cerrar galería';
});

// Adicionales toggle
document.getElementById('btn-adicionales').addEventListener('click', () => {
  const open = addPanel.classList.contains('open');
  addPanel.classList.toggle('open', !open);
  galleryPanel.classList.remove('open');
  document.getElementById('btn-galeria').innerHTML = '<i class="ti ti-sparkles"></i>Crea tu menú';
  document.getElementById('btn-adicionales').innerHTML = open
    ? '<i class="ti ti-plus"></i>Adicionales'
    : '<i class="ti ti-x"></i>Cerrar';
});

// Gallery selection
let selCount = 0;
document.querySelectorAll('.g-item').forEach(item => {
  item.addEventListener('click', () => {
    const was = item.classList.contains('sel');
    item.classList.toggle('sel');
    selCount += was ? -1 : 1;
    const el = document.getElementById('sel-count');
    el.textContent = selCount === 0 ? '0 platos seleccionados' : `${selCount} plato${selCount > 1 ? 's' : ''} seleccionado${selCount > 1 ? 's' : ''}`;
  });
});

// Share
document.getElementById('share-btn').addEventListener('click', () => {
  const t = document.getElementById('toast');
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
});

// Bottom nav
document.querySelectorAll('.nav-i').forEach(n => n.addEventListener('click', () => {
  document.querySelectorAll('.nav-i').forEach(x => x.classList.remove('active'));
  n.classList.add('active');
}));
</script>
</body>
</html>
