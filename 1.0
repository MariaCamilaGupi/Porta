<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Chef Privado — App Mockup</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --gold: #C9A96E;
    --gold-light: #E8C97A;
    --gold-dark: #8B6010;
    --dark: #1C1007;
    --dark2: #231508;
    --dark3: #2A1C08;
    --cream: #FDFAF5;
    --text-main: #2C1A06;
    --text-sub: #7A6040;
    --text-gold-faint: rgba(201,169,110,0.5);
    --border-gold: rgba(201,169,110,0.2);
  }

  body {
    background: #F5F0E8;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: 24px 16px 48px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  }

  /* ── PAGE HEADER ─────────────────────────────────────────── */
  .page-header {
    text-align: center;
    margin-bottom: 28px;
  }
  .page-title {
    font-size: 22px;
    font-weight: 600;
    color: var(--text-main);
    letter-spacing: -0.3px;
  }
  .page-sub {
    font-size: 13px;
    color: var(--text-sub);
    margin-top: 4px;
  }

  /* ── PHONE FRAME ─────────────────────────────────────────── */
  .phone-wrap { display: flex; justify-content: center; }
  .phone {
    width: 340px;
    background: var(--cream);
    border-radius: 36px;
    border: 2.5px solid var(--gold);
    overflow: hidden;
    position: relative;
    outline: 6px solid #1a1209;
    outline-offset: 0;
    /* Fixed height with internal scroll handled per-screen */
  }

  /* ── STATUS BAR ──────────────────────────────────────────── */
  .sb {
    height: 30px; background: var(--dark);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 18px; flex-shrink: 0;
  }
  .sb-t { color: var(--gold-light); font-size: 11px; font-weight: 500; }
  .sb-ic { color: var(--gold-light); font-size: 12px; display: flex; gap: 5px; align-items: center; }

  /* ══════════════════════════════════════════════════════════
     SPLASH SCREEN
  ══════════════════════════════════════════════════════════ */
  #splash {
    position: absolute; inset: 0; z-index: 100;
    background: var(--dark);
    display: flex; align-items: center; justify-content: center;
    flex-direction: column;
    transition: opacity 0.6s ease;
  }
  #splash.hide { opacity: 0; pointer-events: none; }

  .lid-wrap { position: relative; width: 160px; height: 160px; }
  .lid-base {
    width: 160px; height: 160px; border-radius: 50%;
    background: radial-gradient(ellipse at 40% 35%, #E8C97A, #B8860B 50%, #7A5500 100%);
    border: 3px solid var(--gold);
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  .lid-sheen {
    position: absolute; top: 12%; left: 15%; width: 45%; height: 35%;
    background: linear-gradient(135deg, rgba(255,255,255,0.35) 0%, transparent 100%);
    border-radius: 50%;
  }
  .lid-top {
    position: absolute; inset: 0; border-radius: 50%;
    background: linear-gradient(160deg, #D4A843 0%, #8B6010 60%, #4A3200 100%);
    border: 2.5px solid var(--gold);
    transform-origin: top center;
    transition: transform 1.2s cubic-bezier(0.4,0,0.2,1), opacity 0.8s ease;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .lid-top.open { transform: rotateX(80deg) translateY(-20px); opacity: 0; }
  .lid-top-sheen {
    position: absolute; top: 10%; left: 18%; width: 42%; height: 32%;
    background: linear-gradient(135deg, rgba(255,255,255,0.28) 0%, transparent 100%);
    border-radius: 50%;
  }
  .lid-handle {
    width: 36px; height: 18px; border-radius: 18px 18px 0 0;
    background: linear-gradient(to bottom, #E8C97A, #A0720A);
    border: 2px solid var(--gold);
    position: absolute; top: -10px; left: 50%; transform: translateX(-50%);
  }
  .logo-placeholder {
    width: 70px; height: 70px; border-radius: 50%;
    border: 2px dashed rgba(255,255,255,0.4);
    display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.6); font-size: 10px; text-align: center;
    line-height: 1.3;
  }
  .splash-tagline {
    color: var(--gold); font-size: 13px; margin-top: 20px;
    letter-spacing: 2px; text-transform: uppercase;
    opacity: 0; transition: opacity 0.8s ease 0.6s;
  }
  .splash-tagline.show { opacity: 1; }
  .splash-sub { color: var(--text-gold-faint); font-size: 10px; margin-top: 6px; letter-spacing: 1px; }

  /* ══════════════════════════════════════════════════════════
     HOME SCREEN
  ══════════════════════════════════════════════════════════ */
  #home-screen {
    display: flex; flex-direction: column;
    opacity: 0; transition: opacity 0.5s ease;
    height: 688px; /* phone inner height */
    overflow: hidden;
  }
  #home-screen.show { opacity: 1; }

  /* Header */
  .app-header { background: var(--dark); padding: 10px 16px 12px; flex-shrink: 0; }
  .header-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
  .app-logo-sm {
    width: 30px; height: 30px; border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), #8B6010);
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; color: #fff;
  }
  .app-title { color: var(--gold-light); font-size: 15px; font-weight: 500; letter-spacing: 0.5px; }
  .menu-btn {
    width: 32px; height: 32px; border-radius: 8px;
    background: rgba(201,169,110,0.15);
    border: 0.5px solid rgba(201,169,110,0.3);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; position: relative; color: var(--gold); font-size: 18px;
    transition: background 0.2s;
  }
  .menu-btn:hover { background: rgba(201,169,110,0.25); }

  /* Dropdown */
  .dropdown {
    position: absolute; top: 36px; right: 0;
    background: var(--dark3); border: 0.5px solid var(--gold);
    border-radius: 10px; width: 175px; z-index: 50;
    overflow: hidden; display: none;
  }
  .dropdown.open { display: block; }
  .dropdown-item {
    padding: 10px 14px; color: var(--gold-light); font-size: 13px;
    border-bottom: 0.5px solid rgba(201,169,110,0.15);
    cursor: pointer; display: flex; align-items: center; gap: 8px;
  }
  .dropdown-item:last-child { border-bottom: none; }
  .dropdown-item:hover { background: rgba(201,169,110,0.12); }
  .dropdown-item i { font-size: 15px; }

  /* Search */
  .search-bar {
    display: flex; align-items: center; gap: 8px;
    background: rgba(255,255,255,0.07);
    border: 0.5px solid rgba(201,169,110,0.4);
    border-radius: 20px; padding: 7px 12px;
  }
  .search-bar i { color: var(--gold); font-size: 15px; }
  .search-bar input {
    background: none; border: none; outline: none;
    color: #F5EDD8; font-size: 13px; width: 100%;
    font-family: inherit;
  }
  .search-bar input::placeholder { color: rgba(201,169,110,0.4); }

  /* Chips */
  .filters-wrap {
    background: var(--dark2); padding: 8px 12px;
    border-bottom: 0.5px solid rgba(201,169,110,0.15);
    flex-shrink: 0; overflow-x: auto; scrollbar-width: none;
  }
  .filters-wrap::-webkit-scrollbar { display: none; }
  .chips-row { display: flex; gap: 6px; width: max-content; }
  .chip {
    padding: 5px 11px; border-radius: 20px; font-size: 11px; font-weight: 500;
    border: 0.5px solid rgba(201,169,110,0.35);
    background: transparent; color: var(--gold);
    cursor: pointer; white-space: nowrap; transition: all 0.2s; flex-shrink: 0;
  }
  .chip.active { background: var(--gold); color: var(--dark); border-color: var(--gold); }
  .chip:hover:not(.active) { background: rgba(201,169,110,0.12); }

  /* Section label */
  .section-label {
    padding: 12px 16px 6px;
    font-size: 11px; font-weight: 500;
    color: rgba(201,169,110,0.6);
    text-transform: uppercase; letter-spacing: 1.5px;
    background: var(--cream); flex-shrink: 0;
  }

  /* Chef list */
  .chef-list {
    flex: 1; overflow-y: auto; background: var(--cream);
    scrollbar-width: thin; scrollbar-color: var(--gold) transparent;
    padding: 4px 0 8px;
  }
  .chef-card {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 16px; cursor: pointer;
    border-bottom: 0.5px solid rgba(201,169,110,0.12);
    transition: background 0.15s; position: relative;
  }
  .chef-card:hover { background: rgba(201,169,110,0.06); }
  .chef-card:last-child { border-bottom: none; }
  .chef-avatar {
    width: 58px; height: 58px; border-radius: 14px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; font-weight: 500; color: #fff;
    border: 2px solid rgba(201,169,110,0.3); position: relative; overflow: hidden;
  }
  .rating-badge {
    position: absolute; bottom: -1px; right: -1px;
    background: var(--gold); color: var(--dark);
    font-size: 8px; font-weight: 600;
    padding: 2px 4px; border-radius: 4px;
  }
  .chef-info { flex: 1; min-width: 0; }
  .chef-name { font-size: 14px; font-weight: 500; color: var(--text-main); margin-bottom: 2px; }
  .chef-exp {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 10px; color: var(--gold-dark);
    background: rgba(201,169,110,0.12);
    padding: 2px 7px; border-radius: 10px; margin-bottom: 4px;
  }
  .chef-spec { font-size: 11px; color: var(--text-sub); line-height: 1.4; }
  .chef-tags { display: flex; gap: 4px; margin-top: 4px; flex-wrap: wrap; }
  .chef-tag {
    font-size: 9px; padding: 2px 6px; border-radius: 8px;
    background: rgba(99,153,34,0.1); color: #3B6D11;
    border: 0.5px solid rgba(99,153,34,0.25);
  }
  .chef-tag.amber { background: rgba(186,117,23,0.1); color: #633806; border-color: rgba(186,117,23,0.25); }
  .chef-tag.blue  { background: rgba(55,138,221,0.1); color: #042C53; border-color: rgba(55,138,221,0.2); }
  .chef-arrow { color: rgba(201,169,110,0.5); font-size: 16px; flex-shrink: 0; }

  /* ══════════════════════════════════════════════════════════
     CHEF DETAIL SCREEN
  ══════════════════════════════════════════════════════════ */
  #chef-detail {
    position: absolute; inset: 0; z-index: 80;
    background: var(--cream);
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
    display: flex; flex-direction: column; overflow: hidden;
  }
  #chef-detail.show { transform: translateX(0); }

  /* Chef hero header */
  .chef-hero {
    background: var(--dark2); height: 130px;
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden; flex-shrink: 0;
  }
  .chef-hero-bg {
    position: absolute; inset: 0;
    background: repeating-linear-gradient(45deg,#2A1C08 0px,#2A1C08 10px,#231508 10px,#231508 20px);
    opacity: 0.5;
  }
  .chef-avatar-lg {
    width: 80px; height: 80px; border-radius: 20px;
    border: 3px solid var(--gold);
    display: flex; align-items: center; justify-content: center;
    font-size: 28px; font-weight: 500; color: #fff;
    position: relative; z-index: 1;
  }
  .back-btn-d {
    position: absolute; top: 8px; left: 12px; z-index: 2;
    width: 28px; height: 28px; border-radius: 8px;
    background: rgba(28,16,7,0.7); border: 0.5px solid rgba(201,169,110,0.4);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: var(--gold); font-size: 14px;
  }
  .fav-btn-d {
    position: absolute; top: 8px; right: 12px; z-index: 2;
    width: 28px; height: 28px; border-radius: 8px;
    background: rgba(28,16,7,0.7); border: 0.5px solid rgba(201,169,110,0.4);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: var(--gold); font-size: 14px;
  }

  .chef-meta { background: var(--dark); padding: 10px 14px 0; flex-shrink: 0; }
  .chef-name-lg { color: var(--gold-light); font-size: 16px; font-weight: 500; line-height: 1.2; }
  .chef-exp-badge {
    display: inline-flex; align-items: center; gap: 3px;
    background: rgba(201,169,110,0.15); border: 0.5px solid rgba(201,169,110,0.3);
    border-radius: 10px; padding: 2px 8px;
    font-size: 10px; color: var(--gold); margin: 4px 0 3px;
  }
  .star-row { display: flex; align-items: center; gap: 3px; margin-bottom: 2px; }
  .star-row i { font-size: 11px; color: var(--gold); }
  .star-val { font-size: 11px; color: var(--text-gold-faint); }
  .chef-specs-bar {
    display: flex; flex-wrap: wrap; gap: 4px;
    padding: 6px 14px 10px; background: var(--dark);
  }
  .spec-tag {
    font-size: 10px; padding: 3px 8px; border-radius: 10px;
    background: rgba(201,169,110,0.1); border: 0.5px solid rgba(201,169,110,0.25);
    color: var(--gold);
  }

  /* Tabs */
  .tabs-bar {
    display: flex; background: var(--dark2);
    border-top: 0.5px solid rgba(201,169,110,0.15);
    border-bottom: 0.5px solid rgba(201,169,110,0.15);
    flex-shrink: 0;
  }
  .tab {
    flex: 1; padding: 10px 4px; text-align: center;
    font-size: 11px; color: rgba(201,169,110,0.5);
    cursor: pointer; border-bottom: 2px solid transparent;
    transition: all 0.2s;
  }
  .tab.active { color: var(--gold-light); border-bottom-color: var(--gold); }

  /* Scrollable body */
  .detail-body {
    flex: 1; overflow-y: auto; background: var(--cream);
    scrollbar-width: thin; scrollbar-color: var(--gold) transparent;
  }

  /* Action buttons */
  .action-btns { display: flex; gap: 8px; padding: 12px 14px 4px; }
  .btn-galeria {
    flex: 1; display: flex; align-items: center; justify-content: center; gap: 6px;
    background: var(--dark); border: none; border-radius: 20px;
    color: var(--gold-light); font-size: 11px; font-weight: 500;
    padding: 9px 10px; cursor: pointer; transition: background 0.2s; font-family: inherit;
  }
  .btn-galeria:hover { background: var(--dark3); }
  .btn-galeria i { font-size: 14px; }
  .btn-adicionales {
    flex: 1; display: flex; align-items: center; justify-content: center; gap: 6px;
    background: transparent; border: 1.5px solid var(--gold); border-radius: 20px;
    color: var(--gold-dark); font-size: 11px; font-weight: 500;
    padding: 9px 10px; cursor: pointer; transition: all 0.2s; font-family: inherit;
  }
  .btn-adicionales:hover { background: rgba(201,169,110,0.08); }
  .btn-adicionales i { font-size: 14px; }

  /* Gallery panel */
  .gallery-panel { display: none; padding: 0 14px 14px; }
  .gallery-panel.open { display: block; }
  .gallery-section-title {
    font-size: 10px; font-weight: 500; color: var(--gold-dark);
    text-transform: uppercase; letter-spacing: 1.2px; margin: 12px 0 7px;
  }
  .gallery-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 6px; }
  .g-item {
    border-radius: 10px; border: 0.5px solid rgba(201,169,110,0.2);
    overflow: hidden; background: #fff; cursor: pointer;
    transition: transform 0.12s; position: relative;
  }
  .g-item:hover { transform: scale(0.97); }
  .g-item.sel { border-color: var(--gold); border-width: 1.5px; }
  .g-item.sel::after {
    content: '✓'; position: absolute; bottom: 3px; right: 4px;
    width: 14px; height: 14px; border-radius: 50%;
    background: var(--gold); color: var(--dark);
    font-size: 9px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
  }
  .g-img { height: 52px; display: flex; align-items: center; justify-content: center; font-size: 22px; }
  .g-name { padding: 4px 6px 5px; font-size: 10px; color: var(--text-main); font-weight: 500; line-height: 1.3; }

  /* Adicionales panel */
  .add-panel { display: none; padding: 0 14px 14px; }
  .add-panel.open { display: block; }
  .add-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 0; border-bottom: 0.5px solid rgba(201,169,110,0.1);
  }
  .add-item:last-child { border-bottom: none; }
  .add-icon {
    width: 36px; height: 36px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; flex-shrink: 0;
  }
  .add-info { flex: 1; }
  .add-name { font-size: 12px; font-weight: 500; color: var(--text-main); }
  .add-desc { font-size: 10px; color: var(--text-sub); margin-top: 1px; }
  .add-price { font-size: 11px; color: var(--gold-dark); font-weight: 500; white-space: nowrap; }

  /* Menu content */
  .menu-content { padding: 8px 14px 16px; }
  .tab-content { display: none; }
  .tab-content.active { display: block; }
  .day-block { margin-bottom: 14px; }
  .day-label { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
  .day-name { font-size: 12px; font-weight: 500; color: var(--text-main); text-transform: uppercase; letter-spacing: 1px; }
  .day-line { flex: 1; height: 0.5px; background: rgba(201,169,110,0.2); }
  .meal-row {
    display: flex; align-items: flex-start; gap: 8px;
    padding: 7px 0; border-bottom: 0.5px solid rgba(201,169,110,0.08);
  }
  .meal-row:last-child { border-bottom: none; }
  .meal-time-col { width: 56px; flex-shrink: 0; }
  .meal-time { font-size: 9px; text-transform: uppercase; letter-spacing: 0.8px; color: rgba(201,169,110,0.6); font-weight: 500; padding-top: 1px; }
  .meal-icon-wrap { width: 32px; height: 32px; border-radius: 8px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 15px; }
  .meal-details { flex: 1; min-width: 0; }
  .meal-name { font-size: 12px; font-weight: 500; color: var(--text-main); line-height: 1.3; }
  .meal-desc { font-size: 10px; color: var(--text-sub); line-height: 1.4; margin-top: 1px; }
  .meal-tags { display: flex; gap: 3px; margin-top: 3px; flex-wrap: wrap; }
  .mtag { font-size: 9px; padding: 1px 6px; border-radius: 8px; white-space: nowrap; }
  .mtag.v  { background: rgba(99,153,34,0.1);  color: #3B6D11; border: 0.5px solid rgba(99,153,34,0.2); }
  .mtag.gf { background: rgba(186,117,23,0.1); color: #633806; border: 0.5px solid rgba(186,117,23,0.2); }
  .mtag.sf { background: rgba(30,132,73,0.1);  color: #085041; border: 0.5px solid rgba(30,132,73,0.2); }
  .mtag.k  { background: rgba(83,74,183,0.1);  color: #26215C; border: 0.5px solid rgba(83,74,183,0.2); }

  /* Share footer */
  .share-footer {
    padding: 10px 14px 14px; background: var(--cream);
    border-top: 0.5px solid rgba(201,169,110,0.15);
    flex-shrink: 0;
  }
  .share-count-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
  .sel-count { font-size: 11px; color: var(--gold-dark); }
  .share-btn-main {
    width: 100%; background: var(--dark); border: none; border-radius: 20px;
    color: var(--gold-light); font-size: 13px; font-weight: 500;
    padding: 12px 20px; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    transition: background 0.2s; font-family: inherit;
  }
  .share-btn-main:hover { background: var(--dark3); }
  .share-btn-main i { font-size: 16px; }

  /* Toast */
  .toast {
    position: absolute; bottom: 90px; left: 50%; transform: translateX(-50%);
    background: var(--dark); color: var(--gold); font-size: 11px;
    padding: 7px 16px; border-radius: 16px; border: 0.5px solid var(--gold);
    white-space: nowrap; z-index: 200; opacity: 0; transition: opacity 0.3s;
    pointer-events: none;
  }
  .toast.show { opacity: 1; }

  /* Bottom nav */
  .bottom-nav {
    height: 52px; background: var(--dark);
    border-top: 0.5px solid rgba(201,169,110,0.2);
    display: flex; align-items: center; justify-content: space-around;
    padding: 0 8px; flex-shrink: 0;
  }
  .nav-i { display: flex; flex-direction: column; align-items: center; gap: 2px; cursor: pointer; padding: 4px 12px; border-radius: 8px; transition: background 0.15s; }
  .nav-i:hover { background: rgba(201,169,110,0.08); }
  .nav-i i { font-size: 18px; color: rgba(201,169,110,0.4); }
  .nav-i.active i { color: var(--gold); }
  .nav-lbl { font-size: 8px; color: rgba(201,169,110,0.4); }
  .nav-i.active .nav-lbl { color: var(--gold); }
</style>
</head>
<body>

<div class="page-header">
  <div class="page-title">Chef Privado</div>
  <div class="page-sub">Mockup interactivo · Toca los chefs para explorar</div>
</div>

<div class="phone-wrap">
<div class="phone">

  <div class="sb">
    <span class="sb-t">9:41</span>
    <div class="sb-ic">
      <i class="ti ti-wifi"></i>
      <i class="ti ti-battery-2"></i>
    </div>
  </div>

  <!-- ── SPLASH ───────────────────────────────────────────── -->
  <div id="splash">
    <div class="lid-wrap">
